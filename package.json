{
  "name": "ibot",
  "version": "1.0.0",
  "description": "Electron desktop pet platform with Control Center, AI, plugins, and local APIs.",
  "author": "ibot contributors",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:control-center && electron .",
    "dev:control-center": "vite --config src/control-center/vite.config.js --host 127.0.0.1",
    "build:control-center": "vite build --config src/control-center/vite.config.js",
    "pack": "npm run build:control-center && electron-builder --dir",
    "dist": "npm run build:control-center && electron-builder",
    "generate-sprites": "node scripts/generate-sprites.js",
    "check:syntax": "node --check main.js preload.js control-center-preload.js renderer.js scripts/generate-sprites.js src/main/*.js src/main/services/*.js src/main/runtime/*.js src/main/pet-pack/*.js src/main/plugins/*.js src/main/plugins/official/*.js src/shared/*.js src/control-center/src/*.jsx tests/services/*.test.js tests/pet-pack/*.test.js tests/plugins/*.test.js",
    "test": "node --test \"tests/**/*.test.js\""
  },
  "build": {
    "appId": "com.ibot.desktop-pet",
    "productName": "ibot",
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "preload.js",
      "control-center-preload.js",
      "cat_anime/**/*",
      "dist/control-center/**/*",
      "src/main/**/*",
      "src/shared/**/*",
      "package.json"
    ],
    "asar": true,
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.entertainment",
      "target": ["dmg", "zip"]
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.5",
    "vite": "^8.0.16"
  }
}
